# =============================================================================
# Git deploys write into httpdocs/. Anything the app WRITES must either be
# ignored here, or live outside httpdocs (preferred — see config.php).
# =============================================================================

# --- Live data — never commit; a deploy would overwrite the real database ----
data/
uploads/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# --- Secrets ---
# The real secrets file lives OUTSIDE httpdocs (dashboard-secrets.php in the
# domain folder). This entry is belt-and-braces in case a copy lands here.
dashboard-secrets.php

# NOTE: config.php IS committed. It holds no secrets — it just loads
# dashboard-secrets.php from outside the web root and supplies safe defaults.

# --- Setup helpers: keep out of the repo so they can't reappear on a live site
setup.php
health.php

# --- OS / editor noise ---
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/
